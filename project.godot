[application]

config/name="Geowar"
config/description="A world only BLACK and WHITE.
Feel the beauty of geometry."
config/version="0.0.0"
run/main_scene="uid://cddlp6x2v6uyt"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
run/max_fps=144
boot_splash/show_image=false
config/icon="uid://c6f6n4u0h334d"

[autoload]

EasyTransition="*uid://cq0t7o8xelk4k"
GameManager="*uid://dmqbaxdejw562"
SignalManager="*uid://dewtr5cmfkdks"
GlobalAudioPlayer="*uid://55nkb5jg7jy0"
DataManager="*uid://c4qk3afa54td1"

[display]

window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://dqpexf05seg0q"

[dotnet]

project/assembly_name="Geowar"

[editor]

